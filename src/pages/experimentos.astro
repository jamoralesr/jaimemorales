---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import { experiments } from '../data/experiments';
---

<BaseLayout
  title="Experimentos"
  description="Proyectos y experimentos técnicos de Jaime Morales"
>
  <main class="page">
    <header class="head">
      <h1>Experimentos</h1>
      <p class="lead">
        Cosas que estoy construyendo — algunas vivas, otras en exploración,
        todas en curso. Hablo de ellas cuando hay algo que contar.
      </p>
    </header>

    <hr class="divider" />

    <section class="list">
      {experiments.map((exp, i) => (
        <>
          {i > 0 && <hr class="divider" />}
          <ExperimentCard experiment={exp} />
        </>
      ))}
    </section>

    <footer class="page-footer">
      <a href="/">← notas</a>
      <a href="/sobre-mi">sobre mí →</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .head {
    padding: var(--space-xl) 0 var(--space-lg);
  }
  .head h1 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-heading);
    font-weight: 400;
    margin: 0 0 var(--space-sm);
  }
  .lead {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-lead);
    color: var(--color-muted);
    line-height: var(--leading-normal);
    max-width: 60ch;
  }

  .page-footer {
    display: flex;
    justify-content: space-between;
    padding: var(--space-xl) 0;
    margin-top: var(--space-2xl);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .page-footer a {
    color: var(--color-dark);
  }
  .page-footer a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
