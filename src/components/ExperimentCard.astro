---
import type { Experiment, ExperimentStatus } from '../data/experiments';

interface Props {
  experiment: Experiment;
}

const { experiment } = Astro.props;

const statusModifier: Record<ExperimentStatus, string> = {
  'en producción':  'badge--produccion',
  'en desarrollo':  'badge--desarrollo',
  'en exploración': 'badge--exploracion',
  'con clientes':   'badge--clientes',
};

const badgeClass = statusModifier[experiment.status];
---

<article class="experiment">
  <header class="head">
    <h2 class="name">
      {experiment.url ? (
        <a href={experiment.url}>{experiment.name}</a>
      ) : (
        experiment.name
      )}
    </h2>
    <span class:list={['badge', badgeClass]}>
      {experiment.status}
    </span>
  </header>
  <p class="description">{experiment.description}</p>
  <p class="tags">
    {experiment.tags.join(' · ')}
  </p>
</article>

<style>
  .experiment {
    padding: var(--space-lg) 0;
  }

  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .name {
    font-family: var(--font-display);
    font-size: var(--text-list-title);
    color: var(--color-heading);
    font-weight: 400;
    margin: 0;
  }
  .name a {
    color: inherit;
  }
  .name a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: var(--border-radius-md);
  }

  .badge--produccion,
  .badge--clientes {
    background: #d4ede0;
    color: #2a6645;
  }
  .badge--desarrollo {
    background: #faebd7;
    color: #8b4a0f;
  }
  .badge--exploracion {
    background: #e8e4f0;
    color: #4a3a7a;
  }

  @media (prefers-color-scheme: dark) {
    .badge--produccion,
    .badge--clientes {
      background: #1f3a2d;
      color: #8fd1ad;
    }
    .badge--desarrollo {
      background: #3a2a18;
      color: #e4a45f;
    }
    .badge--exploracion {
      background: #2a2438;
      color: #b3a8d4;
    }
  }

  .description {
    font-family: var(--font-body);
    font-size: var(--text-excerpt);
    color: var(--color-body);
    line-height: var(--leading-normal);
    margin: var(--space-sm) 0;
  }

  .tags {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
  }
</style>
