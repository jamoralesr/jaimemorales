---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jaime Morales',
  description = 'Notas sobre IA, tecnología y humanidad.',
} = Astro.props;

const pageTitle = title === 'Jaime Morales' ? title : `${title} — Jaime Morales`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Jaime Morales" href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <hr class="accent-bar" />
    <slot />
    <footer class="site-footer">
      <div class="page">
        <p>© {new Date().getFullYear()} Jaime Morales</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    margin-top: var(--space-3xl);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
  }
  .site-footer p {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }
</style>
