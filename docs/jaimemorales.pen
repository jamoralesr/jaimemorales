                  "fill": "#1a3846",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Desarrollador,\nconsultor, artesano.",
                  "lineHeight": 1.2,
                  "fontFamily": "Playfair Display",
