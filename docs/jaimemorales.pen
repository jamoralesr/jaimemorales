                },
                {
                  "type": "text",
                  "id": "gpSVK",
                  "name": "aHeroSub",
                  "fill": "#5E5954",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Llevo 20 años construyendo cosas en la web. Los últimos tres los he dedicado casi exclusivamente a entender qué significa construir con inteligencia artificial — no encima de ella.",
                  "lineHeight": 1.75,
                  "fontFamily": "Newsreader",
