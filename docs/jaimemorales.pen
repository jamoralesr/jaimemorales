          ],
          "children": [
            {
              "type": "text",
              "id": "IdKgT",
              "name": "aIntLabel",
              "fill": "#9a9088",
              "content": "FUERA DEL CÓDIGO",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 10,
              "fontWeight": "normal",
              "letterSpacing": 3
